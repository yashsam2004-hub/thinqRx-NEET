<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#F8FAFC"/>
  
  <!-- Grid pattern -->
  <defs>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#E2E8F0" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="800" height="600" fill="url(#grid)" />
  
  <!-- Icon -->
  <circle cx="400" cy="250" r="60" fill="#CBD5E1" opacity="0.5"/>
  <path d="M 400 220 L 400 280 M 370 250 L 430 250" stroke="#64748B" stroke-width="4" stroke-linecap="round"/>
  <path d="M 415 235 L 430 250 L 415 265" stroke="#64748B" stroke-width="4" stroke-linecap="round" fill="none"/>
  
  <!-- Text -->
  <text x="400" y="360" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-size="20" fill="#475569" font-weight="500">
    Figure will be generated automatically
  </text>
  <text x="400" y="390" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-size="14" fill="#94A3B8">
    Based on caption provided in content
  </text>
</svg>
