# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================
# CRITICAL: SECURITY & CREDENTIALS
# ============================================

# Environment variables (ALL variants)
.env
.env.*
.env.local
.env.development
.env.production
.env.test
.env.backup
!.env.example
env.example

# Supabase credentials & config
.supabase/
supabase-service-role-key.txt
supabase-anon-key.txt

# API Keys & Secrets
**/api-keys.json
**/credentials.json
**/secrets.*
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt

# Payment Gateway (Razorpay, etc.)
razorpay-*.txt
payment-keys.*
merchant-*.json

# Database dumps & backups
*.sql.backup
*.dump
*.sqlite
*.sqlite3
*.db
database-backup/
db-exports/

# ============================================
# DEPENDENCIES
# ============================================

# Node modules
node_modules/
/.pnp
.pnp.*
.pnp.js

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
yarn-error.log*

# npm
npm-debug.log*
.npm

# pnpm
.pnpm-debug.log*
pnpm-lock.yaml

# ============================================
# NEXT.JS & BUILD
# ============================================

# Next.js
/.next/
/out/
.next/

# Build outputs
/build
/dist
*.tsbuildinfo

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Production
/production

