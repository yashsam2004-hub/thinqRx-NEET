# TESTING & COVERAGE
# ============================================

# Test coverage
/coverage
/coverage.*
.nyc_output
*.lcov

# Test results
/test-results/
/playwright-report/
/playwright/.cache/

# Jest
jest-results.json

# ============================================
# DEVELOPMENT & DEBUGGING
# ============================================

# Debug logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
debug.log
*.log

# Diagnostic files
diagnostic-*.json
/scripts/diagnostics/*.json

# Temporary files
*.tmp
*.temp
.cache/
.temp/

# ============================================
# IDE & EDITOR
# ============================================

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
*.code-workspace

# Cursor
.cursor/
*.cursor

# WebStorm / IntelliJ
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ============================================
# OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ============================================
# DEPLOYMENT & HOSTING
# ============================================

# Vercel
.vercel
.vercel.json

# Docker
docker-compose.override.yml
.dockerignore

# ============================================
# USER DATA & UPLOADS
# ============================================

# User uploads (if any)
/public/uploads/
/uploads/
/user-data/

# Generated content
/generated/
/ai-cache/

# ============================================
# DOCUMENTATION SAFETY
# ============================================

# Backup & old files (keep .md docs, remove backups)
*.backup
*.bak
*.old
*-old.*
*-backup.*
page-old-backup.*

# Personal notes (but keep official docs)
PERSONAL_NOTES.md
TODO_PRIVATE.md
notes-private/

# ============================================
# PACKAGE MANAGER LOCKS
# ============================================

# Keep only one lock file (package-lock.json for npm)
# Uncomment if using different package manager:
# yarn.lock
# pnpm-lock.yaml

# ============================================
# MISCELLANEOUS
# ============================================

# Archives
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Certificates
*.cert

# Local config overrides
*local.config.js
*local.config.ts

# Session files
.sessions/
*.session

# Error logs from tools
*.err

# ============================================
# PROJECT-SPECIFIC (NEET Prep Platform)
# ============================================

# Private reference materials (.pmd files)
/private/
/private/reference-materials/
*.pmd

# Mock test uploads (if sensitive)
# /mock-tests-uploads/

# Analytics data exports
# /analytics-exports/

# Payment transaction logs (sensitive)
payment-logs/
transaction-history/

# Admin panel exports
admin-exports/
user-exports/

# Email templates with credentials
email-config-private.*

# Biology diagrams (before they're finalized)
# /public/biology-diagrams/draft/

# ============================================
# END OF .gitignore
# ============================================
